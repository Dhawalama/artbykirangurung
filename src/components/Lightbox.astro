<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="close" type="button" aria-label="Close artwork preview">×</button>
  <img id="lightbox-image" alt="Artwork preview" />
  <div class="light-caption">
    <h3 id="lightbox-title"></h3>
    <p id="lightbox-category"></p>
  </div>
</div>
