---
const { hero } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path) => `${base}${path}`;
---
<section id="home" class="hero">
  <div class="hero-frame">
    <div class="hero-type">
      <p class="eyebrow">{hero.eyebrow}</p>
      <div>
        <h1 class="hero-title">{hero.firstName}<span>{hero.lastName}</span></h1>
        <span class="hero-mark" aria-hidden="true"></span>
      </div>
      <div class="hero-copy">
        <p>{hero.copy}</p>
        <a href="#portraits" class="text-link">{hero.linkLabel} <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <div class="hero-image">
      <img src={asset(hero.image)} alt="Featured artwork by Kiran Gurung" />
      <div class="hero-caption">{hero.caption}</div>
    </div>
  </div>
</section>
