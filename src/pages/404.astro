---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Page not found — Art by Kiran Gurung" description="Page not found" lang="en">
  <main class="container" style="min-height: 70vh; display:grid; align-content:center;">
    <div class="section-label">404</div>
    <h2>Page not found.</h2>
    <p class="lead" style="margin-top:24px;"><a class="text-link" href={`${base}en/`}>Return home <span>→</span></a></p>
  </main>
</BaseLayout>
