---
const base = import.meta.env.BASE_URL;
const enUrl = `${base}en/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${enUrl}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Art by Kiran Gurung</title>
  </head>
  <body>
    <p><a href={enUrl}>Continue to Art by Kiran Gurung</a></p>
  </body>
</html>
